# Trading Intelligence SaaS - production environment template
# Copy to .env.production for Docker Compose, or enter these values in Render.
# Never commit real secrets.

# ---------------------------------------------------------------------------
# Deployment mode
# ---------------------------------------------------------------------------
APP_ENV=production
API_VERSION_PREFIX=/api/v1

# Public URLs. Use HTTPS in production.
APP_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
BACKEND_API_URL=https://api.example.com/api/v1/signals
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE=https://api.example.com

# Docker Compose port bindings. Render ignores these.
API_PORT=8000
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Database and cache
# ---------------------------------------------------------------------------
# Render injects DATABASE_URL from its managed Postgres service.
# Docker Compose production derives DATABASE_URL from POSTGRES_* unless you
# override DATABASE_URL directly.
DATABASE_URL=postgresql+psycopg2://trading_intelligence:change-me@postgres:5432/trading_intelligence
POSTGRES_DB=trading_intelligence
POSTGRES_USER=trading_intelligence
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Redis is optional but recommended for multi-user rate limiting.
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------------------------
# Auth and account lifecycle
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-32-plus-character-random-secret
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14
JWT_ISSUER=
JWT_AUDIENCE=
ALLOW_PUBLIC_REGISTRATION=false
ACCOUNT_ACTIVATION_TOKEN_TTL_MINUTES=120

# Optional first admin values for manual seed scripts.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-temporary-admin-password

# ---------------------------------------------------------------------------
# CORS, host, and request security
# ---------------------------------------------------------------------------
# FRONTEND_URL is automatically allowed by the backend CORS config.
# Add comma-separated extra origins only when needed.
CORS_ALLOW_ORIGINS=
CORS_ORIGINS=
CORS_ALLOW_CREDENTIALS=false

# APP_URL and FRONTEND_URL hosts are automatically trusted.
# Add comma-separated extra hosts for load balancers or alternate domains.
TRUSTED_HOSTS=

REQUEST_MAX_BODY_BYTES=1048576
WEBHOOK_MAX_BODY_BYTES=2097152
REQUEST_TIMEOUT_SECONDS=30
SECURITY_HSTS_SECONDS=31536000

# ---------------------------------------------------------------------------
# Market/news data providers for non-MT5 production mode
# ---------------------------------------------------------------------------
DATA_PROVIDER=api
MARKET_DATA_PROVIDER=api
CANDLE_PROVIDER=oanda
CANDLE_FALLBACK_PROVIDER=twelvedata
NEWS_PROVIDER=finnhub
DISABLE_MT5=true

OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
OANDA_TIMEOUT_SECONDS=10
OANDA_SYMBOL_MAP_JSON=

TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_TIMEOUT_SECONDS=10
TWELVE_DATA_SYMBOL_MAP_JSON=

FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Oracle engine, direction dashboard, and liquidity targets
# ---------------------------------------------------------------------------
ORACLE_SYMBOL=XAUUSD
ORACLE_TIMEFRAME=M1
ORACLE_ENABLED_SYMBOLS=XAUUSD,GBPJPY,GBPUSD,EURUSD,BTCUSD
ORACLE_LONDON_OPEN_HOUR=8

# Run the scheduler in the worker, not in the web API process.
ORACLE_SCHEDULER_IN_API=false
MARKET_INGEST_HEARTBEAT_ENABLED=false
RUNNER_HEARTBEAT_STALE_SECONDS=180

ORACLE_DAILY_EMA_PERIOD=20
ORACLE_CONFIRM_EMA_PERIOD=50
ORACLE_VOLUME_LOOKBACK=20
ORACLE_VOLUME_LOW_MULT=0.7
ORACLE_VOLUME_HIGH_MULT=1.6
ORACLE_ATR_H1_MIN=0.5
ORACLE_ATR_H1_MAX=60.0
ORACLE_ADR_D1_MIN=5.0
ORACLE_ADR_D1_MAX=300.0
ORACLE_H1_VOLATILITY_RATIO_MAX=3.0
ORACLE_NEWS_WINDOWS_JSON=[]
ORACLE_NEWS_BLOCK_MINUTES=30
ORACLE_CONFIRM_DELAY_MINUTES=15
ORACLE_PRICE_MONITOR_INTERVAL_SECONDS=120
ORACLE_DAILY_AUDIT_HOUR=21
ORACLE_DAILY_AUDIT_MINUTE=0
ORACLE_ASIA_START_HOUR=0
ORACLE_ASIA_END_HOUR=6
ORACLE_ASIA_VOLUME_SPIKE_MULT=1.8
ORACLE_M15_MANIPULATION_LOOKBACK=20
ORACLE_M15_MANIPULATION_Z_WINDOW=96

STRATEGY_MATRIX_ENABLE_ELITE_LIQ_SWEEP_EXPANSION=false
STRATEGY_MATRIX_ENABLE_ELITE_ZONE_TO_ZONE_EXPANSION=false

# ---------------------------------------------------------------------------
# Stripe subscriptions and billing portal
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ELITE=

# Backward-compatible aliases. Keep blank unless older scripts require them.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

BILLING_RENEWAL_REMINDER_HOUR=9
BILLING_RENEWAL_REMINDER_MINUTE=0

# ---------------------------------------------------------------------------
# Telegram integration
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SIGNAL_API_TOKEN=replace-with-random-signal-api-token

# ---------------------------------------------------------------------------
# Runner/control integration
# ---------------------------------------------------------------------------
RUNNER_API_KEY=replace-with-random-runner-api-key
RUNNER_ALLOWED_IPS=
RUNNER_IP_ALLOWLIST=
RUNNER_REQUIRE_IP_ALLOWLIST=false
RUNNER_TRUST_PROXY_HEADERS=false
RUNNER_CONTROL_URL=
RUNNER_CONTROL_TIMEOUT_SECONDS=10
RUNNER_CONTROL_VERIFY_TLS=true

# ---------------------------------------------------------------------------
# Trade execution and local MT5/MT4 controls
# ---------------------------------------------------------------------------
# Keep disabled for the public SaaS unless a separate, audited execution
# service is deployed.
AUTOTRADE_ENABLED=false
AUTOTRADE_ADMIN_EMAIL=admin@example.com
AUTOTRADE_DEFAULT_VOLUME=0.01
AUTOTRADE_MAX_VOLUME=0.10
AUTOTRADE_MAX_TRADES_PER_DAY=3
AUTOTRADE_MAX_OPEN_TRADES_PER_SYMBOL=1
AUTOTRADE_BLOCK_HIGH_RISK=true
AUTOTRADE_NEWS_BLOCK_ENABLED=true

ORACLE_EXEC_DEFAULT_TTL_SECONDS=900
ORACLE_EXEC_MIN_TTL_SECONDS=60
ORACLE_EXEC_MAX_TTL_SECONDS=7200
ORACLE_EXEC_LONDON_START_HOUR=7
ORACLE_EXEC_LONDON_END_HOUR=12
ORACLE_EXEC_NEWYORK_START_HOUR=13
ORACLE_EXEC_NEWYORK_END_HOUR=18
ORACLE_EXEC_ALLOW_OFF_SESSION=false
ORACLE_EXEC_MAX_RISK_PERCENT=0.5
ORACLE_EXEC_MAX_RISK_POINTS=25.0
ORACLE_EXEC_MAX_SPREAD_POINTS=45
ORACLE_EXEC_MAX_POSITIONS=1
ORACLE_EXEC_ENTRY_BUFFER_ATR_MULT=0.20
ORACLE_EXEC_SL_ATR_MULT=0.85
ORACLE_EXEC_TP1_R_MULT=1.5
ORACLE_EXEC_TP2_R_MULT=2.4

ORACLE_EXEC_ADMIN_TOKEN=
ORACLE_EXEC_TARGET_TIER=elite
ORACLE_EXEC_SESSION=auto
ORACLE_EXEC_TTL_SECONDS=900

# Optional local Windows runner only. Do not set these on Render.
MT5_TERMINAL_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
RUNNER_INTERVAL_SECONDS=60
RUNNER_SYMBOLS=XAUUSD,GBPUSD,EURUSD,GBPJPY,BTCUSD
RUNNER_TIMEFRAMES=M1,M15,H1
RUNNER_BROKER_UTC_OFFSET=+00:00
RUNNER_LONDON_TZ=Europe/London
RUNNER_SYMBOL_MAP_JSON=
RUNNER_ID=api-runner-1
RUNNER_VERSION=1.0.0
RUNNER_CONN_CHECK_SECONDS=20
RUNNER_CONTROL_ENABLED=true
RUNNER_CONTROL_BIND=127.0.0.1
RUNNER_CONTROL_PORT=8787
RUNNER_CONTROL_REQUIRE_KEY=true
RUNNER_JOB_POLL_SECONDS=5
RUNNER_HEARTBEAT_SECONDS=30
RUNNER_POS_SYNC_SECONDS=30
RUNNER_REQUEST_TIMEOUT_SECONDS=30
RUNNER_DRY_RUN=false

MT4_SIGNAL_FILE_PATH=
MT4_WRITER_INTERVAL_SECONDS=60
MT4_WRITER_ONCE=false
